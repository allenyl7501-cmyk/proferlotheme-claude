        "z2": { "type": "zone", "settings": { "zone_name": "Metro — other states", "areas": "Sydney, Melbourne, Canberra & other capital-city metro areas", "is_free": false, "cost_label": "Calculated at checkout", "transit_text": "2–5 business days", "in_structured_data": true, "region_country": "AU", "region_codes": "NSW,VIC,ACT", "region_desc": "Capital-city metro areas (other states)", "transit_min": 2, "transit_max": 5 } },
