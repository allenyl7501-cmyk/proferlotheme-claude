      "settings": {
        "eyebrow": "Shipping & Delivery",
        "heading": "Shipping & Delivery Policy",
        "intro": "<p>Everything you need to know about how, when and where we deliver — including delivery zones, estimated timeframes, pickups and our delivery guarantee.</p>",
        "guarantee_title": "Our Shipping Guarantee",
