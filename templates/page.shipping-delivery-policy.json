        "g2": { "type": "guarantee", "settings": { "icon": "people", "title": "Custom Shipping Solution", "text": "<p>Have special shipping needs or an extra-large order? Reach out for a custom solution. <a href='/pages/contact-us'>Click here</a></p>" } },
        "g3": { "type": "guarantee", "settings": { "icon": "shield", "title": "ShipGuard Package Protection", "text": "<p>Optional protection covering theft, loss and damage — peace of mind beyond standard insurance. <a href='/pages/terms-conditions'><em>(T&Cs apply)</em></a></p>" } }
      },
