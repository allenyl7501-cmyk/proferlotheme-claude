        "z4": { "type": "zone", "settings": { "zone_name": "Click & Collect (Pickup)", "areas": "Acacia Ridge 4110 warehouse, Brisbane QLD", "is_free": true, "cost_label": "", "transit_text": "Ready in 24–48 hrs · collect Mon–Fri 10am–4pm", "in_structured_data": false, "region_country": "AU", "region_codes": "QLD", "region_desc": "Warehouse pickup", "transit_min": 0, "transit_max": 0 } }
