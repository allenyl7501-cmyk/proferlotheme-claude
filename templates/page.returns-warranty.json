    "faq_main": {
      "type": "returns-warranty-faq",
      "blocks": {
        "q1": { "type": "faq", "settings": { "question": "How long do I have to return an item?", "answer": "<p>You can request a change-of-mind return within <strong>14 days</strong> of receiving your order. Some items are excluded (such as clearance, ex-display and made-to-order items) — see the Returns details above.</p>" } },
        "q2": { "type": "faq", "settings": { "question": "How do I start a return or warranty claim?", "answer": "<p>Email <strong>support@proferlofurniture.com.au</strong> with your <strong>order number</strong> and supporting evidence — clear <strong>photos</strong> of the item, and for faults a short <strong>video</strong> showing the issue. For change-of-mind returns, include photos of the item and its original packaging. Our team will guide you through the next steps and approve your request before anything is returned.</p>" } },
        "q3": { "type": "faq", "settings": { "question": "What does my warranty cover?", "answer": "<p>Our warranty covers issues that arise from a <strong>manufacturing fault</strong> — defects in materials (such as timber splitting or significant fabric flaws) and workmanship (such as faulty joinery, failed stitching or broken hardware). It does not cover normal wear and tear, accidental damage, misuse, or fading from sunlight. Approved claims are repaired, partially replaced, or fully replaced at our discretion, with shipping &amp; handling covered.</p>" } },
        "q4": { "type": "faq", "settings": { "question": "Will I be charged a fee for a change-of-mind return?", "answer": "<p>Within the 14-day change-of-mind window there is <strong>no restocking fee</strong> on items returned in their original condition and packaging — you only cover the return shipping, and the original delivery cost is deducted from your refund where applicable (including on free-metro and free-promotion orders). A <strong>20% fee</strong> applies to returns made outside the change-of-mind period, or to items not returned in their original packaging or condition. Returning directly to our Acacia Ridge warehouse avoids the return shipping fee.</p>" } },
        "q5": { "type": "faq", "settings": { "question": "Are my consumer rights affected?", "answer": "<p>No. These warranties are <strong>in addition to</strong> your rights under the Australian Consumer Law. Our goods come with guarantees that cannot be excluded under the ACL.</p>" } }
