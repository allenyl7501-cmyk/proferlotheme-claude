      "block_order": ["t1", "t2", "t3", "s1", "s2", "s3"],
      "settings": {
        "heading": "Our Warranty Periods",
        "subtext": "<p>To reflect the quality and durability of our different products, we offer a tiered warranty structure. Every warranty covers defects in materials and workmanship.</p>",
        "covers_title": "What our warranty covers",
        "covers": "<ul><li>Defects in materials, such as timber splitting or significant fabric flaws.</li><li>Defects in workmanship, such as faulty joinery, failed stitching or broken hardware.</li><li>For approved claims we repair, provide a replacement part, or replace the product at our discretion — and cover all associated shipping &amp; handling.</li></ul>",
        "not_covers_title": "What it does not cover",
        "not_covers": "<ul><li>Normal wear and tear from everyday use.</li><li>Damage from improper assembly, cleaning or maintenance.</li><li>Accidental damage such as spills, cuts, stains or pet damage.</li><li>Fading or discolouration from direct or prolonged sunlight exposure.</li><li>Use for a purpose other than intended (e.g. commercial use).</li><li>Personal preference such as comfort or style — covered instead by our 14-day change-of-mind return.</li></ul>",
        "steps_title": "How to Make a Warranty Claim",
        "acl_note": "<p><strong>Your rights under this warranty are in addition to your rights under the Australian Consumer Law.</strong> Our goods come with guarantees that cannot be excluded under the ACL.</p>",
