        "t2": { "type": "tier", "settings": { "term": "3 Years", "title": "Structural Warranty", "text": "<p>An extended warranty on the robust internal frames of our sofas, armchairs and bed frames.</p>", "applies": "Sofas · Armchairs · Bed frames" } },
