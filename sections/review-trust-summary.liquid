{%- liquid
  assign target = section.settings.target_handle | strip
  assign render_section = true
  if target != blank and page.handle != target
    assign render_section = false
  endif
-%}
{%- if render_section -%}
  {%- style -%}
    .pf-trust{display:block}
    .pf-trust__inner{margin:0 auto}
    .pf-trust__title{text-align:center;margin:0 0 2.4rem}
    .pf-trust__grid{list-style:none;margin:0 0 2rem;padding:0;display:grid;grid-template-columns:repeat(auto-fit,minmax(18rem,1fr));gap:1.2rem}
    .pf-trust__card{background:rgba(128,128,128,.07);border-radius:1.2rem;padding:2rem 1.6rem;text-align:center}
    .pf-trust__icon{display:inline-flex;line-height:0}
    .pf-trust__icon svg{width:2.8rem;height:2.8rem}
    .pf-trust__card-title{font-weight:600;margin:1rem 0 .4rem;font-size:1.5rem}
    .pf-trust__card-text{margin:0;font-size:1.2rem;line-height:1.5;opacity:.72}
    .pf-trust__summary{background:rgba(128,128,128,.07);border-radius:1.2rem;padding:2rem 2.4rem}
    .pf-trust__summary-title{font-weight:600;margin:0 0 .8rem;font-size:1.6rem}
    .pf-trust__summary-text{font-size:1.4rem;line-height:1.7;opacity:.82}
    .pf-trust__summary-text > :first-child{margin-top:0}
    .pf-trust__summary-text > :last-child{margin-bottom:0}
    .pf-trust__chips{list-style:none;display:flex;flex-wrap:wrap;gap:.8rem;margin:1.2rem 0 0;padding:0}
    .pf-trust__chip{font-size:1.2rem;border:.1rem solid rgba(128,128,128,.28);border-radius:.8rem;padding:.4rem 1rem;opacity:.85}
    @media (max-width:749px){.pf-trust__grid{grid-template-columns:repeat(2,1fr)}}
  {%- endstyle -%}
  <section class="pf-trust color-{{ section.settings.color_scheme }}" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px" aria-label="{{ section.settings.heading | default: 'Customer trust summary' | escape }}">
    <div class="pf-trust__inner page-width">
      {%- if section.settings.heading != blank -%}
        <h2 class="pf-trust__title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.blocks.size > 0 -%}
        <ul class="pf-trust__grid" role="list">
          {%- for block in section.blocks -%}
            <li class="pf-trust__card" {{ block.shopify_attributes }}>
              <span class="pf-trust__icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'leaf' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20c.6-6 4-10 10-11l2-.4-.4 2C14.6 16.6 10.5 20 4.5 20H4z"/><path d="M5 19c4-5.5 8-8.5 13-9.5"/></svg>
                  {%- when 'truck' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6.5h10.5v9.5H3z"/><path d="M13.5 9.5H17l3.5 3.3V16h-7z"/><circle cx="7" cy="18" r="1.6"/><circle cx="17" cy="18" r="1.6"/></svg>
                  {%- when 'shield' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 2.6v5.2c0 4.2-3 7.4-7 8.6-4-1.2-7-4.4-7-8.6V5.6z"/><path d="M9 12l2 2 4-4"/></svg>
                  {%- when 'star' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.5l2.6 5.3 5.9.9-4.2 4.1 1 5.8L12 17l-5.3 2.8 1-5.8-4.2-4.1 5.9-.9z"/></svg>
                  {%- when 'award' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="5"/><path d="M9 13.5L7.5 21l4.5-2.4L16.5 21 15 13.5"/></svg>
                  {%- else -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M8.5 12l2.5 2.5 4.5-5"/></svg>
                {%- endcase -%}
              </span>
              {%- if block.settings.title != blank -%}<p class="pf-trust__card-title">{{ block.settings.title | escape }}</p>{%- endif -%}
              {%- if block.settings.text != blank -%}<p class="pf-trust__card-text">{{ block.settings.text | escape }}</p>{%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
      {%- if section.settings.show_summary and section.settings.summary_text != blank -%}
        <div class="pf-trust__summary">
          {%- if section.settings.summary_heading != blank -%}<h3 class="pf-trust__summary-title">{{ section.settings.summary_heading | escape }}</h3>{%- endif -%}
          <div class="pf-trust__summary-text rte">{{ section.settings.summary_text }}</div>
          {%- assign kw = section.settings.keywords | split: ',' -%}
          {%- if kw.size > 0 -%}
            <ul class="pf-trust__chips" role="list">
              {%- for k in kw -%}
                {%- assign kt = k | strip -%}
                {%- if kt != blank -%}<li class="pf-trust__chip">{{ kt | escape }}</li>{%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Review trust summary",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Australian homes trust Proferlo" },
    { "type": "text", "id": "target_handle", "label": "Only show on page handle", "default": "our-reviews", "info": "Leave blank to show on every page using this template." },
    { "type": "header", "content": "Summary" },
    { "type": "checkbox", "id": "show_summary", "label": "Show summary block", "default": true },
    { "type": "text", "id": "summary_heading", "label": "Summary heading", "default": "What customers tell us most" },
    { "type": "richtext", "id": "summary_text", "label": "Summary text" },
    { "type": "text", "id": "keywords", "label": "Highlight keywords", "info": "Comma separated.", "default": "Fast delivery, Easy assembly, Solid quality, Great value, Looks great" },
    { "type": "header", "content": "Layout" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Top padding", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Bottom padding", "default": 40 }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Trust pillar",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "verified", "options": [ { "value": "verified", "label": "Verified" }, { "value": "leaf", "label": "Leaf" }, { "value": "truck", "label": "Truck" }, { "value": "shield", "label": "Shield" }, { "value": "star", "label": "Star" }, { "value": "award", "label": "Award" } ] },
        { "type": "text", "id": "title", "label": "Title", "default": "Trust pillar" },
        { "type": "text", "id": "text", "label": "Description" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Review trust summary",
      "blocks": [
        { "type": "pillar", "settings": { "icon": "verified", "title": "Authentic reviews", "text": "Every review is collected and verified through Judge.me from real buyers" } },
        { "type": "pillar", "settings": { "icon": "leaf", "title": "FSC & CARB2 certified", "text": "Responsibly sourced timber and low-emission materials" } },
        { "type": "pillar", "settings": { "icon": "truck", "title": "Fast Australia-wide dispatch", "text": "Shipped from our Brisbane (QLD) warehouse" } },
        { "type": "pillar", "settings": { "icon": "shield", "title": "14-day returns & warranty", "text": "Shop with confidence, backed after delivery" } }
      ]
    }
  ]
}
{% endschema %}
