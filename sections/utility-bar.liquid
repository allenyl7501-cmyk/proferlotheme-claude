{%- assign announcement_blocks = section.blocks | where: "type", "announcement" -%}
{%- assign link_blocks = section.blocks | where: "type", "link" -%}

<style>
  #utility-bar-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.font_size }}px;
    padding: {{ section.settings.padding }}px 20px;
    width: 100%;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    position: relative;
  }

  #utility-bar-{{ section.id }} .utility-bar__announcement-wrap {
    position: relative;
    flex: 1;
    height: 1.5em;
    overflow: hidden;
    text-align: center;
  }

  #utility-bar-{{ section.id }} .utility-bar__announcement {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    opacity: 0;
    transition: opacity 0.5s ease;
    white-space: nowrap;
    color: {{ section.settings.text_color }};
    line-height: 1.5;
  }

  #utility-bar-{{ section.id }} .utility-bar__announcement.is-active {
    opacity: 1;
  }

  #utility-bar-{{ section.id }} .utility-bar__separator {
    opacity: 0.6;
    margin: 0 2px;
  }

  #utility-bar-{{ section.id }} .utility-bar__announcement-link {
    color: {{ section.settings.text_color }};
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  #utility-bar-{{ section.id }} .utility-bar__announcement-link:hover {
    opacity: 0.75;
  }

  #utility-bar-{{ section.id }} .utility-bar__spacer,
  #utility-bar-{{ section.id }} .utility-bar__links {
    display: none;
  }

  @media (min-width: 990px) {
    #utility-bar-{{ section.id }} {
      padding: {{ section.settings.padding }}px 40px;
    }

    #utility-bar-{{ section.id }} .utility-bar__spacer {
      display: block;
      flex: 1;
    }

    #utility-bar-{{ section.id }} .utility-bar__announcement-wrap {
      flex: 0 0 auto;
      max-width: 60%;
    }

    #utility-bar-{{ section.id }} .utility-bar__links {
      display: flex;
      flex: 1;
      justify-content: flex-end;
      list-style: none;
      margin: 0;
      padding: 0;
      gap: {{ section.settings.link_gap }}px;
    }

    #utility-bar-{{ section.id }} .utility-bar__links a {
      color: {{ section.settings.text_color }};
      text-decoration: none;
      white-space: nowrap;
    }

    #utility-bar-{{ section.id }} .utility-bar__links a:hover {
      text-decoration: underline;
      text-underline-offset: 2px;
    }
  }
</style>

<div id="utility-bar-{{ section.id }}" class="utility-bar">

  <div class="utility-bar__spacer" aria-hidden="true"></div>

  {%- if announcement_blocks.size > 0 -%}
    <div class="utility-bar__announcement-wrap" id="ub-announcements-{{ section.id }}">
      {%- for block in announcement_blocks -%}
        <div
          class="utility-bar__announcement{% if forloop.first %} is-active{% endif %}"
          {{ block.shopify_attributes }}
        >
          {{- block.settings.text -}}
          {%- if block.settings.link != blank -%}
            <span class="utility-bar__separator" aria-hidden="true">•</span>
            <a href="{{ block.settings.link }}" class="utility-bar__announcement-link">
              {{- block.settings.link_label | default: 'Learn more' -}}
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if link_blocks.size > 0 -%}
    <ul class="utility-bar__links" id="ub-links-{{ section.id }}">
      {%- for block in link_blocks -%}
        <li {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link }}">{{ block.settings.label }}</a>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

</div>

{%- if announcement_blocks.size > 1 -%}
<script>
  (function () {
    var wrap = document.getElementById('ub-announcements-{{ section.id }}');
    if (!wrap) return;
    var items = wrap.querySelectorAll('.utility-bar__announcement');
    if (items.length < 2) return;
    var current = 0;
    var intervalMs = {{ section.settings.announcement_interval | times: 1000 }};
    setInterval(function () {
      items[current].classList.remove('is-active');
      current = (current + 1) % items.length;
      items[current].classList.add('is-active');
    }, intervalMs);
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Utility Bar",
  "settings": [
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#2C3639"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#DCD7C9"
    },
    {
      "type": "header",
      "content": "Typography & spacing"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 18,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Bar height (vertical padding)",
      "min": 4,
      "max": 20,
      "step": 2,
      "default": 8
    },
    {
      "type": "range",
      "id": "link_gap",
      "label": "Gap between links (desktop)",
      "min": 8,
      "max": 40,
      "step": 2,
      "default": 20
    },
    {
      "type": "header",
      "content": "Announcement rotation"
    },
    {
      "type": "range",
      "id": "announcement_interval",
      "label": "Seconds between each announcement",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "info": "Keep short — one line on mobile.",
          "default": "Free delivery on orders over $500"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Learn more"
        }
      ]
    },
    {
      "type": "link",
      "name": "Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "FAQs"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Utility Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": { "text": "Free delivery on orders over $500" }
        },
        {
          "type": "announcement",
          "settings": { "text": "FSC certified & CARB2 compliant furniture" }
        },
        {
          "type": "announcement",
          "settings": { "text": "Ships Australia-wide via Allied Express" }
        },
        { "type": "link", "settings": { "label": "FAQs" } },
        { "type": "link", "settings": { "label": "Reviews" } },
        { "type": "link", "settings": { "label": "Contact Us" } },
        { "type": "link", "settings": { "label": "Trade" } }
      ]
    }
  ]
}
{% endschema %}