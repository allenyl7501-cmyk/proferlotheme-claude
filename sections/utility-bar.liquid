<div class="utility-bar" style="background-color:{{ section.settings.bg_color }}; padding:{{ section.settings.padding }}px 0;">
  <div style="width:100%; padding:0 60px; box-sizing:border-box; display:flex; justify-content:{{ section.settings.alignment }};">
    <ul style="list-style:none; margin:0; padding:0; display:flex; gap:24px;">
      {% for block in section.blocks %}
        <li>
          <a href="{{ block.settings.link }}" style="color:{{ section.settings.text_color }}; font-size:{{ section.settings.font_size }}px; text-decoration:none;">
            {{ block.settings.label }}
          </a>
        </li>
      {% endfor %}
    </ul>
  </div>
</div>

<style>
  @media (max-width: 1300px) {
    .utility-bar { display: none; }
  }
</style>

{% schema %}
{
  "name": "Utility Bar",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background colour",
      "default": "#1a1a2e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 13
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Bar height (padding)",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 8
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Link alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" },
        { "value": "space-between", "label": "Space between" }
      ],
      "default": "flex-end"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "FAQs"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Utility Bar",
      "blocks": [
        { "type": "link", "settings": { "label": "FAQs" } },
        { "type": "link", "settings": { "label": "Reviews" } },
        { "type": "link", "settings": { "label": "Contact Us" } },
        { "type": "link", "settings": { "label": "Trade" } }
      ]
    }
  ]
}
{% endschema %}