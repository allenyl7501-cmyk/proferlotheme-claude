{%- comment -%}
  Proferlo — Returns & Warranty : TOP section
  Hero + "Our Commitment" intro + highlight cards + two email-claim buttons + optional strip.
  Self-contained, fully editable in the Theme customiser.
  Sizing uses the theme's 10px (62.5%) rem root + theme font variables.
{%- endcomment -%}
<style>
  #rwtop-{{ section.id }}{
    --pf-forest:#2C3639;--pf-teal:#3F4E4F;--pf-linen:#DCD7C9;--pf-copper:#AB764B;--pf-copper-l:#C89568;
    --pf-bg:#F4F1EA;--pf-card:#fff;--pf-cardbd:#E7E1D2;--pf-muted:#5A615C;
    background:var(--pf-bg);padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;
    font-family:var(--font-body-family);
  }
  #rwtop-{{ section.id }} *{box-sizing:border-box;}
  #rwtop-{{ section.id }} .rwwrap{max-width:104rem;margin:0 auto;padding:0 2rem;color:var(--pf-forest);}
  #rwtop-{{ section.id }} .rwhero{text-align:center;margin-bottom:1.2rem;}
  #rwtop-{{ section.id }} .rweyebrow{font-family:var(--font-heading-family);font-size:1.3rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:#6B6B63;margin-bottom:1rem;}
  #rwtop-{{ section.id }} .rwhero h1{font-family:var(--font-heading-family);font-weight:var(--font-heading-weight,700);font-size:var(--font-h2-size);line-height:1.12;margin:0 0 1.2rem;}
  #rwtop-{{ section.id }} .rwintro,#rwtop-{{ section.id }} .rwintro p{font-size:1.7rem;color:var(--pf-muted);line-height:1.6;margin:0 auto;max-width:64rem;}
  #rwtop-{{ section.id }} .rwbtns{display:flex;flex-wrap:wrap;gap:1.2rem;justify-content:center;margin-top:2.4rem;}
  #rwtop-{{ section.id }} a.rwbtn{display:inline-block;text-decoration:none;font-family:var(--font-heading-family);font-weight:600;font-size:1.55rem;padding:1.3rem 3rem;border-radius:.8rem;transition:background .15s,color .15s;}
  #rwtop-{{ section.id }} a.rwbtn--primary{background:var(--pf-copper);color:#fff;}
  #rwtop-{{ section.id }} a.rwbtn--primary:hover{background:#9A6A43;}
  #rwtop-{{ section.id }} a.rwbtn--ghost{background:transparent;color:var(--pf-teal);border:.15rem solid var(--pf-teal);}
  #rwtop-{{ section.id }} a.rwbtn--ghost:hover{background:var(--pf-teal);color:#fff;}
  #rwtop-{{ section.id }} .rwcards{display:grid;grid-template-columns:repeat(3,1fr);gap:1.8rem;margin-top:3.2rem;}
  #rwtop-{{ section.id }} .rwcard{background:var(--pf-card);border:1px solid var(--pf-cardbd);border-radius:1.2rem;padding:2.6rem 2.2rem;text-align:center;}
  #rwtop-{{ section.id }} .rwcard svg{width:4.4rem;height:4.4rem;color:var(--pf-copper);margin:0 auto 1.4rem;}
  #rwtop-{{ section.id }} .rwcard h3{font-family:var(--font-heading-family);font-size:1.9rem;font-weight:700;margin:0 0 .8rem;}
  #rwtop-{{ section.id }} .rwcard .rwtx,#rwtop-{{ section.id }} .rwcard .rwtx p{font-size:1.4rem;color:var(--pf-muted);margin:0;line-height:1.55;}
  #rwtop-{{ section.id }} .rwusp{background:var(--pf-teal);color:var(--pf-linen);text-align:center;font-size:1.6rem;letter-spacing:.02em;padding:1.6rem 2rem;margin-top:3rem;border-radius:1rem;}
  #rwtop-{{ section.id }} .rwusp p{margin:0;}
  #rwtop-{{ section.id }} .rwusp strong{color:#fff;}
  @media (max-width:749px){
    #rwtop-{{ section.id }} .rwcards{grid-template-columns:1fr;}
    #rwtop-{{ section.id }} a.rwbtn{flex:1 1 100%;text-align:center;}
  }
</style>

{%- liquid
  assign sc = section.settings
-%}

<div id="rwtop-{{ section.id }}">
  <div class="rwwrap">
    <div class="rwhero">
      {%- if sc.eyebrow != blank -%}<div class="rweyebrow">{{ sc.eyebrow | escape }}</div>{%- endif -%}
      {%- if sc.heading != blank -%}<h1>{{ sc.heading | escape }}</h1>{%- endif -%}
      {%- if sc.intro != blank -%}<div class="rwintro">{{ sc.intro }}</div>{%- endif -%}

      {%- if sc.btn1_label != blank or sc.btn2_label != blank -%}
      <div class="rwbtns">
        {%- if sc.btn1_label != blank and sc.btn1_url != blank -%}
          <a class="rwbtn rwbtn--primary" href="{{ sc.btn1_url | escape }}">{{ sc.btn1_label | escape }}</a>
        {%- endif -%}
        {%- if sc.btn2_label != blank and sc.btn2_url != blank -%}
          <a class="rwbtn rwbtn--ghost" href="{{ sc.btn2_url | escape }}">{{ sc.btn2_label | escape }}</a>
        {%- endif -%}
      </div>
      {%- endif -%}
    </div>

    {%- assign card_count = 0 -%}
    {%- for block in section.blocks -%}{%- if block.type == 'highlight' -%}{%- assign card_count = card_count | plus: 1 -%}{%- endif -%}{%- endfor -%}

    {%- if card_count > 0 -%}
    <div class="rwcards">
      {%- for block in section.blocks -%}{%- if block.type == 'highlight' -%}
        <div class="rwcard" {{ block.shopify_attributes }}>
          {%- case block.settings.icon -%}
            {%- when 'refresh' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 4v5h-5"/></svg>
            {%- when 'shield' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/><path d="m9 12 2 2 4-4"/></svg>
            {%- when 'tools' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a4 4 0 0 0-5.2 5.2L3 18v3h3l6.5-6.5a4 4 0 0 0 5.2-5.2l-2.5 2.5-2.3-.6-.6-2.3z"/></svg>
            {%- when 'heart' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20s-7-4.3-9.3-9A4.8 4.8 0 0 1 12 6a4.8 4.8 0 0 1 9.3 5C19 15.7 12 20 12 20z"/></svg>
            {%- when 'clock' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2"/></svg>
          {%- endcase -%}
          {%- if block.settings.title != blank -%}<h3>{{ block.settings.title | escape }}</h3>{%- endif -%}
          {%- if block.settings.text != blank -%}<div class="rwtx">{{ block.settings.text }}</div>{%- endif -%}
        </div>
      {%- endif -%}{%- endfor -%}
    </div>
    {%- endif -%}

    {%- if sc.show_usp and sc.usp_text != blank -%}
    <div class="rwusp">{{ sc.usp_text }}</div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Returns & warranty — top",
  "tag": "section",
  "class": "section-rw-top",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow / kicker", "default": "Returns & Warranty" },
    { "type": "text", "id": "heading", "label": "Page heading", "default": "Returns & Warranty" },
    { "type": "richtext", "id": "intro", "label": "Intro / Our Commitment", "default": "<p>We're sure you'll love your Proferlo furniture. If for any reason you're not completely satisfied, you can request a change-of-mind return within 14 days of receiving your order (conditions apply). We'll arrange a swap, replacement or refund. If an item has a fault, we can also arrange replacement parts, repairs or a replacement under warranty.</p>" },
    { "type": "header", "content": "Action buttons" },
    { "type": "text", "id": "btn1_label", "label": "Button 1 label", "default": "Start a return" },
    { "type": "text", "id": "btn1_url", "label": "Button 1 link (mailto / URL)", "info": "Pre-filled email asking for order number + photos.", "default": "mailto:support@proferlofurniture.com.au?subject=Change%20of%20mind%20return%20request&body=Order%20number%3A%0D%0AItem(s)%20to%20return%3A%0D%0AReason%20for%20return%3A%0D%0A%0D%0APlease%20attach%20photos%20of%20the%20item%20and%20its%20original%20packaging." },
    { "type": "text", "id": "btn2_label", "label": "Button 2 label", "default": "Make a warranty claim" },
    { "type": "text", "id": "btn2_url", "label": "Button 2 link (mailto / URL)", "info": "Pre-filled email asking for order number + photos/video.", "default": "mailto:support@proferlofurniture.com.au?subject=Warranty%20claim&body=Order%20number%3A%0D%0ADescription%20of%20the%20fault%3A%0D%0A%0D%0APlease%20attach%20photos%20or%20a%20short%20video%20clearly%20showing%20the%20fault." },
    { "type": "header", "content": "Highlight strip" },
    { "type": "checkbox", "id": "show_usp", "label": "Show highlight strip", "default": true },
    { "type": "richtext", "id": "usp_text", "label": "Strip text", "default": "<p>Faulty item? <strong>We cover shipping &amp; handling on all approved warranty claims.</strong></p>" },
    { "type": "header", "content": "Section spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Top padding", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Bottom padding", "default": 8 }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight card",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "refresh", "options": [
          { "value": "refresh", "label": "Refresh / return" },
          { "value": "shield", "label": "Shield" },
          { "value": "tools", "label": "Tools / repair" },
          { "value": "heart", "label": "Heart" },
          { "value": "clock", "label": "Clock" },
          { "value": "none", "label": "None" }
        ] },
        { "type": "text", "id": "title", "label": "Title", "default": "14-Day Returns" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Changed your mind? Return within 14 days of delivery (conditions apply).</p>" }
      ]
    }
  ],
  "presets": [
    { "name": "Returns & warranty — top", "blocks": [ { "type": "highlight" }, { "type": "highlight" }, { "type": "highlight" } ] }
  ]
}
{% endschema %}
