{%- comment -%}
  Proferlo — Shipping & Delivery Policy : TOP section
  Hero + "Our Shipping Guarantee" cards + free-shipping USP strip.
  Self-contained, fully editable in the Theme customiser.
  Sizing uses the theme's 10px (62.5%) rem root + theme font variables.
{%- endcomment -%}
<style>
  #sdtop-{{ section.id }}{
    --pf-forest:#2C3639;--pf-teal:#3F4E4F;--pf-linen:#DCD7C9;--pf-copper:#AB764B;--pf-copper-l:#C89568;
    --pf-bg:#F4F1EA;--pf-card:#fff;--pf-cardbd:#E7E1D2;--pf-muted:#5A615C;
    background:var(--pf-bg);padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;
    font-family:var(--font-body-family);
  }
  #sdtop-{{ section.id }} *{box-sizing:border-box;}
  #sdtop-{{ section.id }} .sdwrap{max-width:104rem;margin:0 auto;padding:0 2rem;color:var(--pf-forest);}
  #sdtop-{{ section.id }} .sdhero{text-align:center;margin-bottom:1.2rem;}
  #sdtop-{{ section.id }} .sdeyebrow{font-family:var(--font-heading-family);font-size:1.3rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:#6B6B63;margin-bottom:1rem;}
  #sdtop-{{ section.id }} .sdhero h1{font-family:var(--font-heading-family);font-weight:var(--font-heading-weight,700);font-size:var(--font-h2-size);line-height:1.12;margin:0 0 1.2rem;}
  #sdtop-{{ section.id }} .sdintro,#sdtop-{{ section.id }} .sdintro p{font-size:1.7rem;color:var(--pf-muted);line-height:1.6;margin:0 auto;max-width:62rem;}
  #sdtop-{{ section.id }} .sdguar{margin-top:3.2rem;}
  #sdtop-{{ section.id }} .sdguar > h2{text-align:center;font-family:var(--font-heading-family);font-size:var(--font-h3-size);margin:0 0 2.2rem;}
  #sdtop-{{ section.id }} .sdcards{display:grid;grid-template-columns:repeat(3,1fr);gap:1.8rem;}
  #sdtop-{{ section.id }} .sdcard{background:var(--pf-card);border:1px solid var(--pf-cardbd);border-radius:1.2rem;padding:2.6rem 2.2rem;text-align:center;}
  #sdtop-{{ section.id }} .sdcard svg{width:4.4rem;height:4.4rem;color:var(--pf-copper);margin:0 auto 1.4rem;}
  #sdtop-{{ section.id }} .sdcard img{height:4.6rem;width:auto;margin:0 auto 1.4rem;display:block;}
  #sdtop-{{ section.id }} .sdcard h3{font-family:var(--font-heading-family);font-size:1.9rem;font-weight:700;margin:0 0 .8rem;}
  #sdtop-{{ section.id }} .sdcard .sdtx,#sdtop-{{ section.id }} .sdcard .sdtx p{font-size:1.4rem;color:var(--pf-muted);margin:0;line-height:1.55;}
  #sdtop-{{ section.id }} .sdcard a{color:var(--pf-copper);font-weight:600;text-decoration:none;}
  #sdtop-{{ section.id }} .sdcard a:hover{text-decoration:underline;}
  #sdtop-{{ section.id }} .sdusp{background:var(--pf-teal);color:var(--pf-linen);text-align:center;font-size:1.6rem;letter-spacing:.02em;padding:1.6rem 2rem;margin-top:3rem;border-radius:1rem;}
  #sdtop-{{ section.id }} .sdusp p{margin:0;}
  #sdtop-{{ section.id }} .sdusp strong{color:#fff;}
  @media (max-width:749px){
    #sdtop-{{ section.id }} .sdcards{grid-template-columns:1fr;}
  }
</style>

{%- liquid
  assign sc = section.settings
-%}

<div id="sdtop-{{ section.id }}">
  <div class="sdwrap">
    <div class="sdhero">
      {%- if sc.eyebrow != blank -%}<div class="sdeyebrow">{{ sc.eyebrow | escape }}</div>{%- endif -%}
      {%- if sc.heading != blank -%}<h1>{{ sc.heading | escape }}</h1>{%- endif -%}
      {%- if sc.intro != blank -%}<div class="sdintro">{{ sc.intro }}</div>{%- endif -%}
    </div>

    {%- assign guarantee_count = 0 -%}
    {%- for block in section.blocks -%}{%- if block.type == 'guarantee' -%}{%- assign guarantee_count = guarantee_count | plus: 1 -%}{%- endif -%}{%- endfor -%}

    {%- if guarantee_count > 0 -%}
    <div class="sdguar">
      {%- if sc.guarantee_title != blank -%}<h2>{{ sc.guarantee_title | escape }}</h2>{%- endif -%}
      <div class="sdcards">
        {%- for block in section.blocks -%}{%- if block.type == 'guarantee' -%}
          <div class="sdcard" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: height: 92 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {%- else -%}
              {%- case block.settings.icon -%}
                {%- when 'truck' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v9H3z"/><path d="M14 10h4l3 3v3h-7z"/><circle cx="7.5" cy="18" r="1.7"/><circle cx="17" cy="18" r="1.7"/></svg>
                {%- when 'people' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3 20a6 6 0 0 1 12 0"/><circle cx="17" cy="9" r="2.4"/><path d="M15.5 20a5 5 0 0 1 6.5-4.8"/></svg>
                {%- when 'shield' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l8 3v6c0 5-3.5 8-8 9-4.5-1-8-4-8-9V6z"/><path d="m9 12 2 2 4-4"/></svg>
                {%- when 'clock' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2"/></svg>
              {%- endcase -%}
            {%- endif -%}
            {%- if block.settings.title != blank -%}<h3>{{ block.settings.title | escape }}</h3>{%- endif -%}
            {%- if block.settings.text != blank -%}<div class="sdtx">{{ block.settings.text }}</div>{%- endif -%}
          </div>
        {%- endif -%}{%- endfor -%}
      </div>
    </div>
    {%- endif -%}

    {%- if sc.show_usp and sc.usp_text != blank -%}
    <div class="sdusp">{{ sc.usp_text }}</div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Shipping policy — top",
  "tag": "section",
  "class": "section-shipping-top",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow / kicker", "default": "Shipping & Delivery" },
    { "type": "text", "id": "heading", "label": "Page heading", "default": "Shipping & Delivery Policy" },
    { "type": "richtext", "id": "intro", "label": "Intro text", "default": "<p>Everything you need to know about how, when and where we deliver — including delivery zones, estimated timeframes, pickups and our delivery guarantee.</p>" },
    { "type": "header", "content": "Shipping guarantee" },
    { "type": "text", "id": "guarantee_title", "label": "Guarantee heading", "default": "Our Shipping Guarantee" },
    { "type": "header", "content": "Free-shipping strip" },
    { "type": "checkbox", "id": "show_usp", "label": "Show free-shipping strip", "default": true },
    { "type": "richtext", "id": "usp_text", "label": "Strip text", "default": "<p>Free Brisbane Metro Shipping & Free Pickups</p>" },
    { "type": "header", "content": "Section spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Top padding", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Bottom padding", "default": 8 }
  ],
  "blocks": [
    {
      "type": "guarantee",
      "name": "Guarantee card",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "default": "truck", "options": [
          { "value": "truck", "label": "Truck" },
          { "value": "people", "label": "People" },
          { "value": "shield", "label": "Shield" },
          { "value": "clock", "label": "Clock" },
          { "value": "none", "label": "None" }
        ] },
        { "type": "image_picker", "id": "image", "label": "Custom icon image (overrides icon)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Express Shipping" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Nationwide express shipping with real-time SMS & email tracking.</p>" }
      ]
    }
  ],
  "presets": [
    { "name": "Shipping policy — top", "blocks": [ { "type": "guarantee" }, { "type": "guarantee" }, { "type": "guarantee" } ] }
  ]
}
{% endschema %}
