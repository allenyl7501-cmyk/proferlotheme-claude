{%- comment -%} Proferlo custom Trade & Bulk Orders page. Native Shopify contact form (routes to support@, Subject="Trade enquiry") + factory-direct messaging + logistics differentiator block. Editable copy in Theme customiser. Sizing uses the theme 10px (62.5%) rem root + theme font variables. {%- endcomment -%}
<style>
  #tpage-{{ section.id }}{
    --pf-forest:#2C3639;--pf-teal:#3F4E4F;--pf-linen:#DCD7C9;--pf-copper:#AB764B;--pf-copper-l:#C89568;
    --pf-bg:#F4F1EA;--pf-card:#fff;--pf-cardbd:#E7E1D2;--pf-field:#CFC8B6;--pf-muted:#5A615C;
    background:var(--pf-bg);font-family:var(--font-body-family);color:var(--pf-forest);
  }
  #tpage-{{ section.id }} *{box-sizing:border-box;}
  #tpage-{{ section.id }} .twrap{max-width:104rem;margin:0 auto;padding:0 2rem;}
  #tpage-{{ section.id }} .tsec{padding:5.2rem 0;}

  /* hero */
  #tpage-{{ section.id }} .thero{background:linear-gradient(160deg,#2C3639 0%,#3F4E4F 100%);color:var(--pf-linen);padding:{{ section.settings.padding_top }}px 0 5.6rem;}
  #tpage-{{ section.id }} .teyebrow{font-family:var(--font-heading-family);font-size:1.3rem;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:var(--pf-copper-l);margin:0 0 1.4rem;}
  #tpage-{{ section.id }} .thero h1{font-family:var(--font-heading-family);font-weight:var(--font-heading-weight,700);font-size:var(--font-h1-size);line-height:1.12;color:#fff;margin:0 0 1.6rem;max-width:18ch;}
  #tpage-{{ section.id }} .thero .tlede,#tpage-{{ section.id }} .thero .tlede p{font-size:1.8rem;line-height:1.6;color:#D6D1C3;max-width:62ch;margin:0 0 2.6rem;}
  #tpage-{{ section.id }} .tbtn{display:inline-block;background:var(--pf-copper);color:#fff;text-decoration:none;font-family:var(--font-heading-family);font-weight:600;font-size:1.6rem;border-radius:.8rem;padding:1.5rem 2.8rem;border:none;cursor:pointer;transition:background .15s;}
  #tpage-{{ section.id }} .tbtn:hover{background:#9A6A43;}

  #tpage-{{ section.id }} .tsec-h{font-family:var(--font-heading-family);font-weight:600;font-size:var(--font-h3-size);line-height:1.2;margin:0 0 1rem;color:var(--pf-forest);}
  #tpage-{{ section.id }} .tsec-sub,#tpage-{{ section.id }} .tsec-sub p{font-size:1.7rem;color:var(--pf-muted);line-height:1.6;max-width:64ch;margin:0 0 3.2rem;}

  /* advantage */
  #tpage-{{ section.id }} .adv{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;}
  #tpage-{{ section.id }} .adv .card{background:var(--pf-card);border:1px solid var(--pf-cardbd);border-radius:1.4rem;padding:2.6rem;}
  #tpage-{{ section.id }} .adv .ic{width:4.4rem;height:4.4rem;border-radius:1rem;background:#F0E7DC;display:flex;align-items:center;justify-content:center;margin-bottom:1.6rem;}
  #tpage-{{ section.id }} .adv .ic svg{width:2.3rem;height:2.3rem;color:var(--pf-copper);}
  #tpage-{{ section.id }} .adv h3{font-family:var(--font-heading-family);font-size:1.9rem;margin:0 0 .8rem;color:var(--pf-forest);}
  #tpage-{{ section.id }} .adv p{font-size:1.55rem;line-height:1.6;color:var(--pf-muted);margin:0;}

  /* audience */
  #tpage-{{ section.id }} .aud-sec{background:#fff;border-top:1px solid var(--pf-cardbd);border-bottom:1px solid var(--pf-cardbd);}
  #tpage-{{ section.id }} .aud{display:grid;grid-template-columns:repeat(4,1fr);gap:1.6rem;}
  #tpage-{{ section.id }} .aud .a{text-align:center;padding:2.4rem 1.4rem;border:1px solid var(--pf-cardbd);border-radius:1.4rem;background:var(--pf-bg);}
  #tpage-{{ section.id }} .aud .a svg{width:3rem;height:3rem;color:var(--pf-copper);margin-bottom:1.2rem;}
  #tpage-{{ section.id }} .aud .a span{display:block;font-family:var(--font-heading-family);font-weight:600;font-size:1.6rem;color:var(--pf-forest);line-height:1.35;}

  /* logistics differentiator */
  #tpage-{{ section.id }} .logi-sec{background:var(--pf-teal);color:var(--pf-linen);}
  #tpage-{{ section.id }} .logi-sec .tsec-h{color:#fff;}
  #tpage-{{ section.id }} .logi-sec .tlead,#tpage-{{ section.id }} .logi-sec .tlead p{font-size:1.8rem;color:#D6D1C3;max-width:62ch;margin:0 0 3rem;}
  #tpage-{{ section.id }} .logi{display:grid;grid-template-columns:1fr 1fr;gap:1.8rem;}
  #tpage-{{ section.id }} .logi .l{display:flex;gap:1.6rem;background:#34423F;border-radius:1.2rem;padding:2.2rem;}
  #tpage-{{ section.id }} .logi .l svg{width:2.4rem;height:2.4rem;color:var(--pf-copper-l);flex:0 0 2.4rem;margin-top:.2rem;}
  #tpage-{{ section.id }} .logi .l h4{font-family:var(--font-heading-family);font-size:1.7rem;margin:0 0 .6rem;color:#fff;}
  #tpage-{{ section.id }} .logi .l p{font-size:1.5rem;line-height:1.55;color:#CFCABB;margin:0;}
  #tpage-{{ section.id }} .logi .l strong{color:#fff;}

  /* steps */
  #tpage-{{ section.id }} .steps{display:grid;grid-template-columns:repeat(4,1fr);gap:1.6rem;}
  #tpage-{{ section.id }} .steps .s{background:#fff;border:1px solid var(--pf-cardbd);border-radius:1.2rem;padding:2.2rem;text-align:center;}
  #tpage-{{ section.id }} .steps .n{width:3.4rem;height:3.4rem;border-radius:50%;background:var(--pf-copper);color:#fff;font-family:var(--font-heading-family);font-weight:600;font-size:1.6rem;display:flex;align-items:center;justify-content:center;margin:0 auto 1.2rem;}
  #tpage-{{ section.id }} .steps .s strong{display:block;font-family:var(--font-heading-family);font-size:1.6rem;color:var(--pf-forest);margin-bottom:.4rem;}
  #tpage-{{ section.id }} .steps .s span{font-size:1.4rem;color:var(--pf-muted);line-height:1.5;}

  /* form */
  #tpage-{{ section.id }} .form-sec{background:#fff;border-top:1px solid var(--pf-cardbd);}
  #tpage-{{ section.id }} .fgrid{display:grid;grid-template-columns:1.12fr 1fr;gap:2.4rem;align-items:start;}
  #tpage-{{ section.id }} .fcard{background:var(--pf-bg);border:1px solid var(--pf-cardbd);border-radius:1.4rem;padding:2.8rem;}
  #tpage-{{ section.id }} .fcard h2{font-family:var(--font-heading-family);font-weight:600;font-size:2.4rem;margin:0 0 .6rem;color:var(--pf-forest);}
  #tpage-{{ section.id }} .fcard .fnote{font-size:1.5rem;color:var(--pf-muted);margin:0 0 2.2rem;}
  #tpage-{{ section.id }} .field{display:block;margin-bottom:1.6rem;}
  #tpage-{{ section.id }} .field>span{display:block;font-size:1.45rem;font-weight:600;color:var(--pf-teal);margin-bottom:.6rem;}
  #tpage-{{ section.id }} .field .opt{color:#A7A293;font-weight:400;}
  #tpage-{{ section.id }} .two{display:grid;grid-template-columns:1fr 1fr;gap:1.4rem;}
  #tpage-{{ section.id }} .fcard input,#tpage-{{ section.id }} .fcard select,#tpage-{{ section.id }} .fcard textarea{width:100%;border:1px solid var(--pf-field);background:#fff;border-radius:.8rem;padding:1.3rem 1.4rem;font-family:var(--font-body-family);font-size:1.6rem;color:var(--pf-forest);}
  #tpage-{{ section.id }} .fcard textarea{min-height:12rem;resize:vertical;}
  #tpage-{{ section.id }} .fcard input:focus,#tpage-{{ section.id }} .fcard select:focus,#tpage-{{ section.id }} .fcard textarea:focus{outline:2px solid var(--pf-copper);outline-offset:1px;border-color:var(--pf-copper);}
  #tpage-{{ section.id }} .submit{margin-top:.6rem;width:100%;background:var(--pf-copper);color:#fff;border:none;border-radius:.8rem;padding:1.6rem;font-family:var(--font-heading-family);font-size:1.7rem;font-weight:600;cursor:pointer;transition:background .15s;}
  #tpage-{{ section.id }} .submit:hover{background:#9A6A43;}
  #tpage-{{ section.id }} .tsuccess{background:#E4F0E8;border:1px solid #BBD9C7;color:#1E5E45;border-radius:.8rem;padding:1.2rem 1.3rem;font-size:1.5rem;line-height:1.5;margin-bottom:1.6rem;}
  #tpage-{{ section.id }} .terrors{margin-bottom:1.6rem;color:#A32D2D;font-size:1.5rem;}
  #tpage-{{ section.id }} .terrors ul{margin:0;padding-left:1.8rem;}
  #tpage-{{ section.id }} .info{background:var(--pf-teal);border-radius:1.4rem;padding:2.8rem;color:var(--pf-linen);}
  #tpage-{{ section.id }} .info h2{font-family:var(--font-heading-family);color:#fff;font-size:2.2rem;margin:0 0 2rem;}
  #tpage-{{ section.id }} .irow{display:flex;gap:1.4rem;margin-bottom:1.8rem;}
  #tpage-{{ section.id }} .irow svg{width:2rem;height:2rem;color:var(--pf-copper-l);flex:0 0 2rem;margin-top:.2rem;}
  #tpage-{{ section.id }} .ilab{font-size:1.2rem;text-transform:uppercase;letter-spacing:.05em;color:#A9B0A8;}
  #tpage-{{ section.id }} .ival,#tpage-{{ section.id }} .ival a{font-size:1.6rem;color:#fff;text-decoration:none;}
  #tpage-{{ section.id }} .ival a:hover{text-decoration:underline;}
  #tpage-{{ section.id }} .ibox{display:flex;gap:1.2rem;background:#34423F;border-radius:.8rem;padding:1.4rem;font-size:1.5rem;line-height:1.5;color:#D6D1C3;margin-top:.8rem;}
  #tpage-{{ section.id }} .ibox svg{width:2rem;height:2rem;color:var(--pf-copper-l);flex:0 0 2rem;margin-top:.2rem;}
  #tpage-{{ section.id }} .ibox strong{color:#fff;}

  @media (max-width:820px){
    #tpage-{{ section.id }} .adv,#tpage-{{ section.id }} .aud,#tpage-{{ section.id }} .logi,#tpage-{{ section.id }} .steps{grid-template-columns:1fr;}
    #tpage-{{ section.id }} .fgrid{grid-template-columns:1fr;}
    #tpage-{{ section.id }} .two{grid-template-columns:1fr;}
  }
</style>

{%- liquid
  assign sc = section.settings
-%}

<div id="tpage-{{ section.id }}">

  <header class="thero">
    <div class="twrap">
      {%- if sc.eyebrow != blank -%}<p class="teyebrow">{{ sc.eyebrow | escape }}</p>{%- endif -%}
      {%- if sc.heading != blank -%}<h1>{{ sc.heading | escape }}</h1>{%- endif -%}
      {%- if sc.intro != blank -%}<div class="tlede">{{ sc.intro }}</div>{%- endif -%}
      {%- if sc.cta_label != blank -%}<a class="tbtn" href="#trade-enquire">{{ sc.cta_label | escape }}</a>{%- endif -%}
    </div>
  </header>

  <section class="tsec">
    <div class="twrap">
      {%- if sc.adv_heading != blank -%}<h2 class="tsec-h">{{ sc.adv_heading | escape }}</h2>{%- endif -%}
      {%- if sc.adv_sub != blank -%}<div class="tsec-sub">{{ sc.adv_sub }}</div>{%- endif -%}
      <div class="adv">
        <div class="card">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1v22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
          <h3>Factory-direct pricing &amp; trade discounts</h3>
          <p>You're buying from the maker, not a reseller. Trade and bulk orders receive trade discounts, negotiated case-by-case on volume.</p>
        </div>
        <div class="card">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9 12 3l9 6"/><path d="M5 10v10h14V10"/><path d="M9 20v-6h6v6"/></svg></div>
          <h3>Order direct from the factory</h3>
          <p>Place orders straight with our manufacturing facility. For large projects we can arrange container-volume orders shipped factory-direct — freight quoted and paid case by case.</p>
        </div>
        <div class="card">
          <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><rect x="7" y="12" width="3" height="6"/><rect x="12" y="8" width="3" height="10"/><rect x="17" y="5" width="3" height="13"/></svg></div>
          <h3>Built for volume</h3>
          <p>Multi-unit orders, repeat-spec ranges and staged deliveries are routine for us — not an exception.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="tsec aud-sec">
    <div class="twrap">
      {%- if sc.aud_heading != blank -%}<h2 class="tsec-h">{{ sc.aud_heading | escape }}</h2>{%- endif -%}
      {%- if sc.aud_sub != blank -%}<div class="tsec-sub">{{ sc.aud_sub }}</div>{%- endif -%}
      <div class="aud">
        <div class="a"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M5 21V7l8-4 8 4v14"/><path d="M9 9h.01M9 12h.01M9 15h.01M13 9h.01M13 12h.01M13 15h.01"/></svg><span>Interior designers &amp; stylists</span></div>
        <div class="a"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 22h20"/><path d="M4 22V4l8-2v20"/><path d="M12 22V9l8 3v10"/></svg><span>Property developers &amp; builders</span></div>
        <div class="a"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11 12 3l9 8"/><path d="M5 10v10h14V10"/><path d="M10 20v-5h4v5"/></svg><span>Airbnb &amp; short-stay operators</span></div>
        <div class="a"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="13" rx="1"/><path d="M8 8V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v3"/><path d="M12 12v4"/></svg><span>Commercial &amp; hospitality fit-outs</span></div>
      </div>
    </div>
  </section>

  <section class="tsec logi-sec">
    <div class="twrap">
      {%- if sc.logi_heading != blank -%}<h2 class="tsec-h">{{ sc.logi_heading | escape }}</h2>{%- endif -%}
      {%- if sc.logi_lead != blank -%}<div class="tlead">{{ sc.logi_lead }}</div>{%- endif -%}
      <div class="logi">
        <div class="l"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="10" rx="1"/><path d="M3 12h18"/><path d="M7 18v2M17 18v2"/></svg><div><h4>Palletised freight</h4><p>Bulk orders dispatched <strong>by pallet</strong> for safe, cost-effective volume delivery anywhere in Australia.</p></div></div>
        <div class="l"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="14" height="11" rx="1"/><path d="M15 9h4l3 3v5h-7z"/><circle cx="6" cy="19" r="2"/><circle cx="18" cy="19" r="2"/></svg><div><h4>Use your own freight account</h4><p>Have rates with <strong>Toll, StarTrack, FedEx</strong> or another carrier? Ship on your account — we prep and label to suit.</p></div></div>
        <div class="l"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg><div><h4>We coordinate with your courier</h4><p>Proferlo can liaise directly with <strong>alternative business couriers</strong> to schedule pickups and book deliveries.</p></div></div>
        <div class="l"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7h13v10H2z"/><path d="M15 10h4l3 3v4h-7z"/><path d="M2 7 6 3h9"/></svg><div><h4>Container-volume orders</h4><p>For large projects, <strong>full-container solutions</strong> arranged on request — shipped factory-direct, freight quoted and paid by the customer.</p></div></div>
      </div>
    </div>
  </section>

  <section class="tsec">
    <div class="twrap">
      {%- if sc.steps_heading != blank -%}<h2 class="tsec-h">{{ sc.steps_heading | escape }}</h2>{%- endif -%}
      {%- if sc.steps_sub != blank -%}<div class="tsec-sub">{{ sc.steps_sub }}</div>{%- endif -%}
      <div class="steps">
        <div class="s"><div class="n">1</div><strong>Enquire</strong><span>Tell us what you need and your rough quantities.</span></div>
        <div class="s"><div class="n">2</div><strong>We quote</strong><span>Tailored trade pricing and freight options.</span></div>
        <div class="s"><div class="n">3</div><strong>You confirm</strong><span>Approve the quote and lock in the order.</span></div>
        <div class="s"><div class="n">4</div><strong>We dispatch</strong><span>By pallet, your courier, or container.</span></div>
      </div>
    </div>
  </section>

  <section class="tsec form-sec" id="trade-enquire">
    <div class="twrap">
      <div class="fgrid">
        <div class="fcard">
          {%- if sc.form_heading != blank -%}<h2>{{ sc.form_heading | escape }}</h2>{%- endif -%}
          {%- if sc.form_note != blank -%}<p class="fnote">{{ sc.form_note | escape }}</p>{%- endif -%}
          {%- form 'contact' -%}
            {%- if form.posted_successfully? -%}
              <div class="tsuccess">Thanks — your trade enquiry is in. We'll reply {{ sc.reply_time | downcase | default: 'within 24 hours' }}.</div>
            {%- endif -%}
            {%- if form.errors -%}
              <div class="terrors">{{ form.errors | default_errors }}</div>
            {%- endif -%}
            <input type="hidden" name="contact[Subject]" value="Trade enquiry">
            <div class="two">
              <label class="field"><span>Name</span><input type="text" name="contact[name]" autocomplete="name" required></label>
              <label class="field"><span>Business name</span><input type="text" name="contact[Business name]" autocomplete="organization" required></label>
            </div>
            <div class="two">
              <label class="field"><span>Email</span><input type="email" name="contact[email]" autocomplete="email" required></label>
              <label class="field"><span>Phone <span class="opt">(optional)</span></span><input type="text" name="contact[Phone]" autocomplete="tel"></label>
            </div>
            <div class="two">
              <label class="field"><span>ABN <span class="opt">(optional)</span></span><input type="text" name="contact[ABN]"></label>
              <label class="field"><span>Buyer type</span>
                <select name="contact[Buyer type]">
                  <option>Interior designer / stylist</option>
                  <option>Property developer / builder</option>
                  <option>Airbnb / short-stay operator</option>
                  <option>Commercial / hospitality fit-out</option>
                  <option>Reseller / retailer</option>
                  <option>Other</option>
                </select>
              </label>
            </div>
            <div class="two">
              <label class="field"><span>Estimated order size / budget <span class="opt">(optional)</span></span><input type="text" name="contact[Estimated order size]" placeholder="e.g. 20 units, or $15k&ndash;$30k"></label>
              <label class="field"><span>Preferred freight</span>
                <select name="contact[Preferred freight]">
                  <option>Use Proferlo's freight</option>
                  <option>I'll use my own freight account</option>
                  <option>Coordinate with my courier</option>
                  <option>Container-volume order</option>
                  <option>Not sure yet</option>
                </select>
              </label>
            </div>
            <label class="field"><span>Project / product details</span><textarea name="contact[body]" placeholder="Tell us the products, quantities, delivery location and timeframe." required></textarea></label>
            <button type="submit" class="submit">{{ sc.submit_label | default: 'Send trade enquiry' | escape }}</button>
          {%- endform -%}
        </div>

        <aside class="info">
          {%- if sc.info_heading != blank -%}<h2>{{ sc.info_heading | escape }}</h2>{%- endif -%}
          {%- if sc.email != blank -%}
          <div class="irow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg><div><div class="ilab">Email</div><div class="ival"><a href="mailto:{{ sc.email | escape }}">{{ sc.email | escape }}</a></div></div></div>
          {%- endif -%}
          {%- if sc.show_phone and sc.phone != blank -%}
          <div class="irow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h3.4l1.8 4.5-2.3 1.5a12 12 0 0 0 5.6 5.6l1.5-2.3 4.5 1.8V19a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg><div><div class="ilab">Phone</div><div class="ival"><a href="tel:{{ sc.phone | remove: ' ' | remove: '(' | remove: ')' }}">{{ sc.phone | escape }}</a></div></div></div>
          {%- endif -%}
          {%- if sc.hours != blank -%}
          <div class="irow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2"/></svg><div><div class="ilab">Trade enquiries answered</div><div class="ival">{{ sc.hours | escape }}</div></div></div>
          {%- endif -%}
          {%- if sc.online_note != blank -%}
          <div class="ibox"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9 12 3l9 6"/><path d="M5 10v10h14V10"/></svg><div>{{ sc.online_note }}</div></div>
          {%- endif -%}
        </aside>
      </div>
    </div>
  </section>
</div>

{%- if sc.enable_faq_schema -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"Do you offer trade or bulk furniture pricing?","acceptedAnswer":{"@type":"Answer","text":"Yes. Proferlo is factory-owned, so trade and bulk buyers order direct and receive trade discounts, negotiated case-by-case based on order volume, product mix and freight method."}},
    {"@type":"Question","name":"Who is eligible for trade pricing?","acceptedAnswer":{"@type":"Answer","text":"Interior designers and stylists, property developers and builders, Airbnb and short-stay operators, and commercial or hospitality fit-outs."}},
