{%- comment -%} Proferlo custom contact page — native Shopify contact form + key info panel. All copy editable in Theme customiser. Sizing uses the theme's 10px (62.5%) rem root + theme font variables. {%- endcomment -%}
<style>
  #cpage-{{ section.id }}{
    --pf-forest:#2C3639;--pf-teal:#3F4E4F;--pf-linen:#DCD7C9;--pf-copper:#AB764B;--pf-copper-l:#C89568;
    --pf-bg:#F4F1EA;--pf-card:#fff;--pf-cardbd:#E7E1D2;--pf-field:#CFC8B6;--pf-muted:#5A615C;
    background:var(--pf-bg);padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;
    font-family:var(--font-body-family);
  }
  #cpage-{{ section.id }} *{box-sizing:border-box;}
  #cpage-{{ section.id }} .cwrap{max-width:104rem;margin:0 auto;padding:0 2rem;color:var(--pf-forest);}
  #cpage-{{ section.id }} .chero{text-align:center;margin-bottom:2.4rem;}
  #cpage-{{ section.id }} .chero h1{font-family:var(--font-heading-family);font-weight:var(--font-heading-weight,700);font-size:var(--font-h2-size);line-height:1.15;color:var(--pf-forest);margin:0 0 .8rem;}
  #cpage-{{ section.id }} .cintro,#cpage-{{ section.id }} .cintro p{font-size:1.7rem;color:var(--pf-muted);line-height:1.6;margin:0 auto;max-width:54rem;}
  #cpage-{{ section.id }} .cquick{background:var(--pf-card);border:1px solid var(--pf-cardbd);border-radius:1.2rem;padding:1.5rem 1.7rem;margin-bottom:2rem;}
  #cpage-{{ section.id }} .cquick-l{display:block;font-family:var(--font-heading-family);font-size:1.3rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:#6B6B63;margin-bottom:1.1rem;}
  #cpage-{{ section.id }} .cpills{display:flex;flex-wrap:wrap;gap:1rem;}
  #cpage-{{ section.id }} .cpill{display:inline-flex;align-items:center;gap:.7rem;font-size:1.5rem;font-weight:600;color:var(--pf-teal);text-decoration:none;border:1px solid #D7D0BF;border-radius:999px;padding:.8rem 1.5rem;background:#fff;transition:background .15s,border-color .15s;}
  #cpage-{{ section.id }} .cpill:hover{background:#FBFAF6;border-color:var(--pf-copper);}
  #cpage-{{ section.id }} .cpill svg{width:1.8rem;height:1.8rem;color:var(--pf-copper);flex:0 0 1.8rem;}
  #cpage-{{ section.id }} .cgrid{display:grid;grid-template-columns:1.12fr 1fr;gap:1.8rem;align-items:start;}
  #cpage-{{ section.id }} .cform-card{background:var(--pf-card);border:1px solid var(--pf-cardbd);border-radius:1.2rem;padding:2.2rem;}
  #cpage-{{ section.id }} .cform-card h2,#cpage-{{ section.id }} .cinfo h2{font-family:var(--font-heading-family);font-weight:600;font-size:2.1rem;line-height:1.2;margin:0 0 1.6rem;}
  #cpage-{{ section.id }} .cform-card h2{color:var(--pf-forest);}
  #cpage-{{ section.id }} .cfield{display:block;margin-bottom:1.3rem;}
  #cpage-{{ section.id }} .cfield > span{display:block;font-size:1.45rem;font-weight:600;color:var(--pf-teal);margin-bottom:.5rem;}
  #cpage-{{ section.id }} .cfield .opt{color:#A7A293;font-weight:400;}
  #cpage-{{ section.id }} .ctwo{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;}
  #cpage-{{ section.id }} .cform-card input,#cpage-{{ section.id }} .cform-card select,#cpage-{{ section.id }} .cform-card textarea{width:100%;border:1px solid var(--pf-field);background:#fff;border-radius:.8rem;padding:1.1rem 1.2rem;font-family:var(--font-body-family);font-size:1.6rem;color:var(--pf-forest);}
  #cpage-{{ section.id }} .cform-card textarea{min-height:12rem;resize:vertical;}
  #cpage-{{ section.id }} .cform-card input:focus,#cpage-{{ section.id }} .cform-card select:focus,#cpage-{{ section.id }} .cform-card textarea:focus{outline:2px solid var(--pf-copper);outline-offset:1px;border-color:var(--pf-copper);}
  #cpage-{{ section.id }} .cbtn{margin-top:.6rem;width:100%;background:var(--pf-copper);color:#fff;border:none;border-radius:.8rem;padding:1.4rem;font-family:var(--font-heading-family);font-size:1.7rem;font-weight:600;cursor:pointer;transition:background .15s;}
  #cpage-{{ section.id }} .cbtn:hover{background:#9A6A43;}
  #cpage-{{ section.id }} .csuccess{background:#E4F0E8;border:1px solid #BBD9C7;color:#1E5E45;border-radius:.8rem;padding:1.1rem 1.2rem;font-size:1.5rem;line-height:1.5;margin-bottom:1.4rem;}
  #cpage-{{ section.id }} .cerrors{margin-bottom:1.4rem;color:#A32D2D;font-size:1.5rem;}
  #cpage-{{ section.id }} .cerrors ul{margin:0;padding-left:1.8rem;}
  #cpage-{{ section.id }} .cinfo{background:var(--pf-teal);border-radius:1.2rem;padding:2.2rem;color:var(--pf-linen);}
  #cpage-{{ section.id }} .cinfo h2{color:#fff;}
  #cpage-{{ section.id }} .irow{display:flex;gap:1rem;margin-bottom:1.4rem;}
  #cpage-{{ section.id }} .irow svg,#cpage-{{ section.id }} .ibox svg{width:2rem;height:2rem;color:var(--pf-copper-l);flex:0 0 2rem;margin-top:.2rem;}
  #cpage-{{ section.id }} .ilab{font-size:1.2rem;text-transform:uppercase;letter-spacing:.04em;color:#A9B0A8;}
  #cpage-{{ section.id }} .ival,#cpage-{{ section.id }} .ival a{font-size:1.6rem;color:#fff;text-decoration:none;}
  #cpage-{{ section.id }} .ival a:hover{text-decoration:underline;}
  #cpage-{{ section.id }} .inote{font-size:1.3rem;color:#A9B0A8;margin-top:.3rem;}
  #cpage-{{ section.id }} .idiv{border-top:1px solid #55625F;padding-top:1.4rem;margin-top:.4rem;}
  #cpage-{{ section.id }} .ibox{display:flex;gap:1rem;background:#34423F;border-radius:.8rem;padding:1.2rem;margin-bottom:1rem;}
  #cpage-{{ section.id }} .ibox:last-child{margin-bottom:0;}
  #cpage-{{ section.id }} .ibox .itx,#cpage-{{ section.id }} .ibox .itx p{font-size:1.5rem;line-height:1.5;color:#D6D1C3;margin:0;}
  #cpage-{{ section.id }} .ibox .itx strong{color:#fff;font-weight:600;}
  @media (max-width:749px){
    #cpage-{{ section.id }} .cgrid{grid-template-columns:1fr;}
    #cpage-{{ section.id }} .ctwo{grid-template-columns:1fr;}
  }
</style>

{%- liquid
  assign sc = section.settings
-%}

<div id="cpage-{{ section.id }}">
  <div class="cwrap">
    <div class="chero">
      {%- if sc.heading != blank -%}<h1>{{ sc.heading | escape }}</h1>{%- endif -%}
      {%- if sc.intro != blank -%}<div class="cintro">{{ sc.intro }}</div>{%- endif -%}
    </div>

    {%- if sc.show_links -%}
    <div class="cquick">
      {%- if sc.links_label != blank -%}<span class="cquick-l">{{ sc.links_label | escape }}</span>{%- endif -%}
      <div class="cpills">
        {%- if sc.link1_url != blank -%}<a class="cpill" href="{{ sc.link1_url }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9.6 9.4a2.4 2.4 0 0 1 4.4 1.3c0 1.6-2 2-2 3.4"/><path d="M12 17.3h.01"/></svg>{{ sc.link1_label | escape }}</a>{%- endif -%}
        {%- if sc.link2_url != blank -%}<a class="cpill" href="{{ sc.link2_url }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h11v9H3z"/><path d="M14 9h4l3 3v3h-7z"/><circle cx="7.5" cy="18" r="1.6"/><circle cx="17" cy="18" r="1.6"/></svg>{{ sc.link2_label | escape }}</a>{%- endif -%}
        {%- if sc.link3_url != blank -%}<a class="cpill" href="{{ sc.link3_url }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 2.6-6.3"/><path d="M3 4.5V9h4.5"/></svg>{{ sc.link3_label | escape }}</a>{%- endif -%}
        {%- if sc.link4_url != blank -%}<a class="cpill" href="{{ sc.link4_url }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>{{ sc.link4_label | escape }}</a>{%- endif -%}
      </div>
    </div>
    {%- endif -%}

    <div class="cgrid">
      <div class="cform-card">
        {%- if sc.form_heading != blank -%}<h2>{{ sc.form_heading | escape }}</h2>{%- endif -%}
        {%- form 'contact' -%}
          {%- if form.posted_successfully? -%}
            <div class="csuccess">Thanks — we’ve got your message and will reply {{ sc.reply_time | downcase | default: 'as soon as possible' }}.</div>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="cerrors">{{ form.errors | default_errors }}</div>
          {%- endif -%}
          <div class="ctwo">
            <label class="cfield"><span>Name</span><input type="text" name="contact[name]" autocomplete="name" required></label>
            <label class="cfield"><span>Email</span><input type="email" name="contact[email]" autocomplete="email" required></label>
          </div>
          <div class="ctwo">
            <label class="cfield"><span>Order number <span class="opt">(optional)</span></span><input type="text" name="contact[Order number]"></label>
            <label class="cfield"><span>Subject</span>
              <select name="contact[Subject]">
                <option>General enquiry</option>
                <option>Order status</option>
                <option>Delivery &amp; freight</option>
                <option>Returns &amp; warranty</option>
                <option>Trade enquiry</option>
              </select>
            </label>
          </div>
          <label class="cfield"><span>Message</span><textarea name="contact[body]" required></textarea></label>
          <button type="submit" class="cbtn">Send message</button>
        {%- endform -%}
      </div>

      <aside class="cinfo">
        {%- if sc.info_heading != blank -%}<h2>{{ sc.info_heading | escape }}</h2>{%- endif -%}
        {%- if sc.email != blank -%}
        <div class="irow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg><div><div class="ilab">Email</div><div class="ival"><a href="mailto:{{ sc.email | escape }}">{{ sc.email | escape }}</a></div></div></div>
        {%- endif -%}
        {%- if sc.show_phone and sc.phone != blank -%}
        <div class="irow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h3.4l1.8 4.5-2.3 1.5a12 12 0 0 0 5.6 5.6l1.5-2.3 4.5 1.8V19a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg><div><div class="ilab">Phone</div><div class="ival"><a href="tel:{{ sc.phone | remove: ' ' | remove: '(' | remove: ')' }}">{{ sc.phone | escape }}</a></div></div></div>
        {%- endif -%}
        {%- if sc.Live_support_hours != blank -%}
        <div class="irow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7.5V12l3 2"/></svg><div><div class="ilab">Support hours</div><div class="ival">{{ sc.support_hours | escape }}</div></div></div>
        {%- endif -%}
        {%- if sc.reply_time != blank -%}
        <div class="irow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 2.6-6.3"/><path d="M3 4.5V9h4.5"/></svg><div><div class="ilab">Reply time</div><div class="ival">{{ sc.reply_time | escape }}</div>{%- if sc.reply_note != blank -%}<div class="inote">{{ sc.reply_note | escape }}</div>{%- endif -%}</div></div>
        {%- endif -%}

        <div class="idiv">
          {%- if sc.walkins_note != blank -%}
          <div class="ibox"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M5.6 5.6l12.8 12.8"/></svg><div class="itx">{{ sc.walkins_note }}</div></div>
          {%- endif -%}
          {%- if sc.dispatch_address != blank -%}
          <div class="ibox"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V8l9-4 9 4v13"/><path d="M3 21h18"/><path d="M9 21v-5h6v5"/></svg><div class="itx">{%- if sc.dispatch_heading != blank -%}<strong>{{ sc.dispatch_heading | escape }}</strong><br>{%- endif -%}{{ sc.dispatch_address }}</div></div>
          {%- endif -%}
        </div>
      </aside>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact page",
  "tag": "section",
  "class": "section-contact-page",
  "settings": [
    { "type": "text", "id": "heading", "label": "Page heading", "default": "Get in touch" },
    { "type": "richtext", "id": "intro", "label": "Intro text", "default": "<p>Questions about an order, a product, or delivery? Drop us a message and we’ll get back to you within 24 hours.</p>" },
    { "type": "text", "id": "form_heading", "label": "Form heading", "default": "Send us a message" },
    { "type": "header", "content": "Info panel" },
    { "type": "text", "id": "info_heading", "label": "Panel heading", "default": "Other ways to reach us" },
    { "type": "text", "id": "email", "label": "Email address", "default": "support@proferlofurniture.com.au" },
    { "type": "checkbox", "id": "show_phone", "label": "Show phone number", "default": true },
    { "type": "text", "id": "phone", "label": "Phone", "default": "(07) 3088 3457" },
    { "type": "text", "id": "support_hours", "label": "Support hours", "default": "Mon–Fri, 10am–4pm AEST" },
    { "type": "text", "id": "reply_time", "label": "Reply time", "default": "Within 24 hours" },
    { "type": "text", "id": "reply_note", "label": "Reply time note", "default": "incl. enquiries sent outside support hours" },
    { "type": "header", "content": "Store & dispatch note" },
    { "type": "richtext", "id": "walkins_note", "label": "Online-only / no walk-ins note", "default": "<p>We’re an <strong>online-only store</strong> — no public showroom, and we don’t accept walk-ins.</p>" },
    { "type": "text", "id": "dispatch_heading", "label": "Dispatch heading", "default": "Dispatch warehouse" },
    { "type": "richtext", "id": "dispatch_address", "label": "Dispatch address", "default": "<p>5 Success Street, Acacia Ridge QLD 4110<br>Dispatch only — not open to the public.</p>" },
    { "type": "header", "content": "Quick answer links" },
    { "type": "checkbox", "id": "show_links", "label": "Show quick links", "default": true },
    { "type": "text", "id": "links_label", "label": "Links label", "default": "Before you message — quick answers" },
    { "type": "text", "id": "link1_label", "label": "Link 1 label", "default": "FAQ" },
    { "type": "text", "id": "link1_url", "label": "Link 1 URL", "default": "/pages/frequently-asked-questions" },
    { "type": "text", "id": "link2_label", "label": "Link 2 label", "default": "Shipping & Pick Up" },
    { "type": "text", "id": "link2_url", "label": "Link 2 URL", "default": "/pages/shipping-pick-up" },
    { "type": "text", "id": "link3_label", "label": "Link 3 label", "default": "Returns & Warranty" },
    { "type": "text", "id": "link3_url", "label": "Link 3 URL", "default": "/pages/returns-warranty" },
    { "type": "text", "id": "link4_label", "label": "Link 4 label", "default": "Trade" },
    { "type": "text", "id": "link4_url", "label": "Link 4 URL (placeholder)", "default": "#" },
    { "type": "header", "content": "Section spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Top padding", "default": 40 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Bottom padding", "default": 72 }
  ],
  "presets": [ { "name": "Contact page" } ]
}
{% endschema %}
