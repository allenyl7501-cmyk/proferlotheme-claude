{%- comment -%}
  Proferlo — Buy Now, Pay Later : Q&A ACCORDION
  Explicit, AI-extractable Q&A headings (native <details>, no JS).
  Emits Schema.org FAQPage JSON-LD from the same blocks (toggle).
  Use ONE instance of this section per page so the FAQPage stays consolidated.
  Optional closing CTA panel.
{%- endcomment -%}
<style>
  #bnfaq-{{ section.id }}{
    --pf-forest:#2C3639;--pf-teal:#3F4E4F;--pf-linen:#DCD7C9;--pf-copper:#AB764B;
    --pf-bg:#F4F1EA;--pf-card:#fff;--pf-cardbd:#E7E1D2;--pf-muted:#5A615C;
    background:var(--pf-bg);padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;
    font-family:var(--font-body-family);
  }
  #bnfaq-{{ section.id }} *{box-sizing:border-box;}
  #bnfaq-{{ section.id }} .bnwrap{max-width:104rem;margin:0 auto;padding:0 2rem;color:var(--pf-forest);}
  #bnfaq-{{ section.id }} .bnfaq-h{text-align:center;font-family:var(--font-heading-family);font-size:var(--font-h3-size);margin:0 0 .6rem;}
  #bnfaq-{{ section.id }} .bnfaq-sub,#bnfaq-{{ section.id }} .bnfaq-sub p{text-align:center;color:var(--pf-muted);font-size:1.5rem;max-width:64rem;margin:0 auto 2.4rem;}
  #bnfaq-{{ section.id }} details{background:#fff;border:1px solid var(--pf-cardbd);border-radius:1rem;margin-bottom:1rem;}
  #bnfaq-{{ section.id }} summary{cursor:pointer;list-style:none;padding:1.6rem 1.8rem;font-weight:600;font-size:1.6rem;color:var(--pf-forest);display:flex;justify-content:space-between;gap:1.2rem;align-items:center;}
  #bnfaq-{{ section.id }} summary::-webkit-details-marker{display:none;}
  #bnfaq-{{ section.id }} summary .bnchev{flex:0 0 auto;color:var(--pf-copper);font-size:1.8rem;line-height:1;transition:transform .2s;}
  #bnfaq-{{ section.id }} details[open] summary .bnchev{transform:rotate(45deg);}
  #bnfaq-{{ section.id }} .bna{padding:0 1.8rem 1.6rem;font-size:1.45rem;color:var(--pf-muted);line-height:1.6;}
  #bnfaq-{{ section.id }} .bna p{margin:0 0 1rem;}
  #bnfaq-{{ section.id }} .bna p:last-child{margin-bottom:0;}
  #bnfaq-{{ section.id }} .bna a{color:var(--pf-copper);font-weight:600;}
  #bnfaq-{{ section.id }} .bna ul,#bnfaq-{{ section.id }} .bna ol{margin:.6rem 0 1rem;padding-left:2rem;}
  #bnfaq-{{ section.id }} .bna li{margin-bottom:.6rem;}
  #bnfaq-{{ section.id }} .bna strong{color:var(--pf-forest);}
  #bnfaq-{{ section.id }} .bncta{background:var(--pf-teal);color:var(--pf-linen);border-radius:1.2rem;text-align:center;padding:4rem 2.4rem;margin-top:2.6rem;}
  #bnfaq-{{ section.id }} .bncta h3,#bnfaq-{{ section.id }} .bncta h3 *{color:#fff;font-family:var(--font-heading-family);font-size:var(--font-h4-size);margin:0 0 1.8rem;}
  #bnfaq-{{ section.id }} .bncta a.bnbtn{display:inline-block;background:var(--pf-copper);color:#fff;text-decoration:none;font-family:var(--font-heading-family);font-weight:600;font-size:1.6rem;padding:1.4rem 3.4rem;border-radius:.8rem;}
  #bnfaq-{{ section.id }} .bncta a.bnbtn:hover{background:#9A6A43;}
</style>

{%- liquid
  assign sc = section.settings
-%}

<div id="bnfaq-{{ section.id }}">
  <div class="bnwrap">
    {%- if sc.heading != blank -%}<h2 class="bnfaq-h">{{ sc.heading | escape }}</h2>{%- endif -%}
    {%- if sc.subtext != blank -%}<div class="bnfaq-sub">{{ sc.subtext }}</div>{%- endif -%}

    {%- for block in section.blocks -%}{%- if block.type == 'faq' -%}
      <details {{ block.shopify_attributes }}>
        <summary>{{ block.settings.question | escape }}<span class="bnchev">+</span></summary>
        <div class="bna">{{ block.settings.answer }}</div>
      </details>
    {%- endif -%}{%- endfor -%}

    {%- if sc.show_cta -%}
    <div class="bncta">
      {%- if sc.cta_heading != blank -%}<h3>{{ sc.cta_heading }}</h3>{%- endif -%}
      {%- if sc.cta_button_label != blank and sc.cta_button_url != blank -%}
        <a class="bnbtn" href="{{ sc.cta_button_url }}">{{ sc.cta_button_label | escape }}</a>
      {%- endif -%}
    </div>
    {%- endif -%}
  </div>
</div>

{%- comment -%} ===== Schema.org FAQPage structured data (for Google & AI assistants) ===== {%- endcomment -%}
{%- if sc.emit_jsonld -%}
{%- capture faq_items -%}
  {%- for block in section.blocks -%}{%- if block.type == 'faq' and block.settings.question != blank -%}
    ,{
      "@type":"Question",
      "name":{{ block.settings.question | strip_html | strip_newlines | json }},
      "acceptedAnswer":{
        "@type":"Answer",
        "text":{{ block.settings.answer | strip_html | strip_newlines | json }}
      }
    }
  {%- endif -%}{%- endfor -%}
{%- endcapture -%}
<script type="application/ld+json">
{
  "@context":"https://schema.org",
  "@type":"FAQPage",
  "name":{{ page.title | default: sc.heading | json }},
  "url":{{ canonical_url | json }},
  "dateModified":"{{ 'now' | date: '%Y-%m-%d' }}",
  "publisher":{"@type":"Organization","name":{{ shop.name | json }}},
  "mainEntity":[{{ faq_items | remove_first: ',' }}]
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "BNPL — FAQ",
  "tag": "section",
  "class": "section-bnpl-faq",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Buy Now, Pay Later — FAQs" },
    { "type": "richtext", "id": "subtext", "label": "Sub-text", "default": "<p>Quick answers to the most common questions about paying later on furniture.</p>" },
    { "type": "header", "content": "Structured data (JSON-LD)" },
    { "type": "paragraph", "content": "Embeds invisible Schema.org FAQPage data so Google & AI assistants can read and quote these answers. Keep ONE instance of this section per page." },
    { "type": "checkbox", "id": "emit_jsonld", "label": "Embed FAQPage structured data", "default": true },
    { "type": "header", "content": "Closing CTA" },
    { "type": "checkbox", "id": "show_cta", "label": "Show closing CTA", "default": true },
    { "type": "richtext", "id": "cta_heading", "label": "CTA heading", "default": "<p>Ready to furnish now and pay later?</p>" },
    { "type": "text", "id": "cta_button_label", "label": "Button label", "default": "Shop Furniture" },
    { "type": "url", "id": "cta_button_url", "label": "Button link" },
    { "type": "header", "content": "Section spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Top padding", "default": 32 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Bottom padding", "default": 56 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Q&A",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "Do you offer Afterpay?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Yes. Afterpay is available at checkout on all Proferlo furniture.</p>" }
      ]
    }
  ],
  "presets": [ { "name": "BNPL — FAQ", "blocks": [ { "type": "faq" } ] } ]
}
{% endschema %}
